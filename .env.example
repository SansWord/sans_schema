# Copy this to `.env` and fill in your values, then:
#   docker run -p 8000:8000 --env-file .env sans-schema:dev
# `.env` is gitignored — NEVER commit real keys.

# --- Backend (required) ---
# Postgres DSN the gateway introspects.
# For the container path below, `localhost` would point at the gateway container
# itself — use host.docker.internal to reach the demo Postgres published on the host.
# (Running uvicorn locally instead? Use localhost:5432 here.)
DATABASE_URL=postgresql://postgres:pg@host.docker.internal:5432/postgres

# --- LLM ---
# Any LiteLLM model id (default: gemini/gemini-3.1-flash-lite).
LLM_MODEL=gemini/gemini-3.1-flash-lite
# Set the API key your model's provider expects — the one matching LLM_MODEL.
# (e.g. GEMINI_API_KEY, ANTHROPIC_API_KEY, OPENAI_API_KEY). Leave the others unset.
GEMINI_API_KEY=

# --- Gateway tuning (optional; defaults shown) ---
GATE_THRESHOLD=0.7
RESULT_LIMIT=100
