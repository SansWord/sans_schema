# Copy this to `.env` and fill in your values, then:
#   docker run -p 8000:8000 --env-file .env sans-schema:dev
# `.env` is gitignored — NEVER commit real keys.

# --- Backend (required) ---
# Postgres DSN the gateway introspects.
# Running the gateway as a container on the shared `sans` network (see the README):
# use the Postgres CONTAINER NAME as the host — `localhost` would mean the gateway
# container itself. (Running uvicorn locally instead? Use localhost:5432 here.)
DATABASE_URL=postgresql://postgres:pg@sans-pg:5432/postgres

# --- LLM ---
# Any LiteLLM model id (default: gemini/gemini-3.1-flash-lite).
LLM_MODEL=gemini/gemini-3.1-flash-lite
# Set the API key your model's provider expects — the one matching LLM_MODEL.
# (e.g. GEMINI_API_KEY, ANTHROPIC_API_KEY, OPENAI_API_KEY). Leave the others unset.
GEMINI_API_KEY=

# --- Gateway tuning (optional; defaults shown) ---
GATE_THRESHOLD=0.7
RESULT_LIMIT=100

# --- Ingress limits (bound the untrusted request → LLM cost/DoS) ---
MAX_WANT_FIELDS=50
MAX_FIELD_LEN=200
MAX_WHERE_LEN=2000

# --- Debug introspection (/debug/prompts, /debug/schema, /debug/cache) ---
# OFF by default. /debug/schema and /debug/cache disclose schema + sample data +
# query history — enable only for local/dev inspection, never on a public gateway.
ENABLE_DEBUG_ENDPOINTS=0

# --- Public-demo guardrails (ALL OFF when empty — leave empty for local dev) ---
# slowapi rate strings (https://limits.readthedocs.io/): "10/minute", "1000/day".
RATE_LIMIT_PER_IP=
DAILY_REQUEST_CAP=
# Comma-separated browser origins allowed to call the API (the playground URL).
CORS_ORIGINS=
# Proxy header carrying the real visitor IP (Fly-Client-IP on Fly.io,
# X-Forwarded-For on Render/Railway). Empty → the socket peer address.
CLIENT_IP_HEADER=

# --- Backend view ---
# The flat (denormalized) view the gateway introspects. Point at your own view
# when running against your own data.
DB_VIEW=books_view
